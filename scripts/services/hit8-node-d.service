[Unit]
Description=HIT#8 - Nodo D: Registro via gRPC (gRPC 5007, HTTP interno 8088)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/SD2026-GRUPO404-TP1/tp1
Environment=GRPC_PORT=5007
ExecStart=/home/ubuntu/SD2026-GRUPO404-TP1/.venv/bin/uvicorn HIT8.node_d:app \
    --host 0.0.0.0 \
    --port 8088
Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
