[Unit]
Description=HIT#4 - Nodo C1 bidireccional (escucha 5003, conecta 5004)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/SD2026-GRUPO404
ExecStart=/home/ubuntu/SD2026-GRUPO404/.venv/bin/python tp1/HIT4/node_c.py \
    --listen-port 5003 \
    --remote-host 127.0.0.1 \
    --remote-port 5004
Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
