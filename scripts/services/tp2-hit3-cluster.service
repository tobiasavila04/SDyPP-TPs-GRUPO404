[Unit]
Description=TP2 HIT#3 - Cluster Bully con nginx (LB :6080, nodos :7001-7003)
After=network.target docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
User=ubuntu
WorkingDirectory=/home/ubuntu/SD2026-GRUPO404-TP1/tp2/HIT3
Environment=LB_PORT=6080
ExecStart=/usr/bin/docker-compose up --build -d
ExecStop=/usr/bin/docker-compose down
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
